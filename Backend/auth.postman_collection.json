        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"resumeId\": \"123456\",\n  \"jobDescription\": \"We need a Node.js developer with Prisma and MongoDB experience\"\n}"
        },
        "url": "http://localhost:3000/api/resume/match"
      }
    },
    {
      "name": "Resume - Feedback",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer YOUR_TOKEN_HERE" }
        ],
        "url": "http://localhost:3000/api/resume/feedback?resumeId=123456"
      }
    },
